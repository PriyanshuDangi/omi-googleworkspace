{
  "name": "omi-googleworkspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Omi Chat Tools App for Google Workspace",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/views && mkdir -p dist/views && cp -r src/views/. dist/views/",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@googleworkspace/cli": "^0.5.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "google-auth-library": "^9.0.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  }
}
